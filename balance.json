  "skillCost": { "pt": 1, "gold": "round(140 * 1.42^currentLv)" },

  "rebirth": {
    "requireLv": "100 + rebirth*25",
    "_requireLv_note": "v3.0: 30+reb*10 → 100+reb*25. 첫 환생 Lv100, 이후 회차당 +25 (reb1:100 reb2:125 reb3:150…). 환생이 '큰 결단'이 되도록 상향.",
    "keep": ["dex", "rebirth", "bestRegion", "bestStage"],
    "grant": { "gems": 40, "skillPt": "rebirth+2", "gold": "round(1500 + 600*rebirth)", "stones": "round(60 + 35*rebirth)" },
    "_grant_note": "v3.0: 환생 간격이 길어진 만큼 재시작 부스트 상향. 골드 1500+600*reb(reb1:2100 reb5:4500), 강화석 60+35*reb.",
    "permanent": { "powerMul": "1 + 1.6*(1 - 0.86^rebirth)", "goldMul": "1 + 0.7*(1 - 0.88^rebirth)", "idleCapHours": "min(24, 8+rebirth)" },
