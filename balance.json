{
  "version": 1,
  "_note": "단일 원본. 클라이언트와 서버(전투력/보상 검증)가 이 파일 하나만 참조한다.",

  "currencies": { "gold": "🪙", "stones": "💠", "gems": "💎", "energy": "⚡" },
  "start": { "lv": 1, "gold": 60, "stones": 0, "gems": 30, "energy": 30, "arenaPts": 1000 },

  "energy": { "max": 30, "regenMs": 80000, "hastePerLv": 0.05, "killPerEnergy": 5 },

  "level": { "expNeed": "round(80 * lv^1.55)", "onLevelUp": { "skillPt": 1, "gems": 2 } },
  "_level_note": "v3.0: expNeed 지수 1.5→1.55. 첫 환생이 Lv100으로 상향됨에 따라 후반 곡선을 완만하게 강화 → Lv100 누적경험치 약 3.9M, '한 시즌 목표'화.",

  "power": {
    "formula": "floor((12 + lv*4 + bestStageEff*3 + gearPow) * (1+atk_lv*0.06) * (1+dexBonusPct/100) * rebirthMul)",
    "_note": "lv 기여 줄임(6→4), stageEff 기여 높임(2→3): 레벨만으로 강해지는 구조 완화",
    "bestStageEff": "min((bestRegion-1)*10 + bestStage, 60 + lv*8 + rebirth*90)",
    "_bestStageEff_note": "캡은 환생으로 완화되지만 환생 기여 축소(150→90)로 격차 통제. 실제 스테이지 도달 필요.",
    "gearPow": "sum(itemPow)",
    "itemPow": "round(item.power * (1 + plus*0.13))",
    "dexBonusPct": "dexCount * 1.2 * (1 + collect_lv*0.25)",
    "rebirthMul": "1 + 1.6*(1 - 0.86^rebirth)",
    "_rebirthMul_note": "점근 곡선(감소수익, ~2.6x 상한). reb1:1.22 reb5:1.85 reb20:2.52. 레퍼런스: 쿠키클리커/NGU Idle 프레스티지. 환생은 필수지만 고/저환생 격차 압축."
  },

  "combat": {
    "playerDmg": "max(3, round(power*0.8))",
    "critChance": 0.05,
    "critMult": 1.8,
    "enemyHp": "round((18 + region*22 + stage*6) * (boss?6:1) * (1 + bestRegion*0.05))",
    "stageKills": 10,
    "stagesPerRegion": 10,
    "combo": { "windowMs": 2800, "goldMultPerCombo": 0.04, "comboCap": 25 }
  },

  "killReward": {
    "bossMult": 8,
    "gold": "round((5 + region*4 + stage) * rand(0.85,1.15) * m * wealthMul * comboMult)",
    "exp": "round((4 + region*2.2 + stage*0.6) * rand(0.85,1.15) * m)",
    "stoneBoss": "round((6 + region*2) * wealthMul)",
    "stoneNormalChance": 0.25,
    "stoneNormal": "round(1 + region*0.5)",
    "dropChanceBoss": 0.9,
    "dropChanceNormal": "0.10 + luck_lv*0.01"
  },

  "rarity": [
