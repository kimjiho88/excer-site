{
  "version": 1,
  "_note": "단일 원본. 클라이언트와 서버(전투력/보상 검증)가 이 파일 하나만 참조한다.",

  "currencies": { "gold": "🪙", "stones": "💠", "gems": "💎", "energy": "⚡" },
  "start": { "lv": 1, "gold": 60, "stones": 0, "gems": 30, "energy": 30, "arenaPts": 1000 },

  "energy": { "max": 30, "regenMs": 80000, "hastePerLv": 0.05, "killPerEnergy": 5 },

  "level": { "expNeed": "round(80 * lv^1.35)", "onLevelUp": { "skillPt": 1, "gems": 2 } },

  "power": {
    "formula": "floor((12 + lv*6 + bestStageEff*2 + gearPow) * (1+atk_lv*0.06) * (1+dexBonusPct/100) * (1+rebirth*0.25))",
    "bestStageEff": "min((bestRegion-1)*10 + bestStage, 100 + lv*14 + rebirth*100)",
    "gearPow": "sum(itemPow)",
    "itemPow": "round(item.power * (1 + plus*0.13))",
    "dexBonusPct": "dexCount * 1.2 * (1 + collect_lv*0.25)",
    "rebirthMul": "1 + rebirth*0.25"
  },

  "combat": {
    "playerDmg": "max(3, round(power*0.8))",
    "critChance": 0.05,
    "critMult": 1.8,
    "enemyHp": "round((18 + region*22 + stage*6) * (boss?6:1) * (1 + bestRegion*0.05))",
    "stageKills": 8,
    "stagesPerRegion": 10,
    "combo": { "windowMs": 2800, "goldMultPerCombo": 0.04, "comboCap": 25 }
  },

  "killReward": {
    "bossMult": 8,
    "gold": "round((5 + region*4 + stage) * rand(0.85,1.15) * m * wealthMul * comboMult)",
    "exp": "round((4 + region*2.2 + stage*0.6) * rand(0.85,1.15) * m)",
    "stoneBoss": "round((6 + region*2) * wealthMul)",
    "stoneNormalChance": 0.25,
    "stoneNormal": "round(1 + region*0.5)",
    "dropChanceBoss": 0.9,
    "dropChanceNormal": "0.13 + luck_lv*0.01"
  },

  "rarity": [
    { "key": "일반", "w": 62,       "mul": 1.0,  "color": "#9aa0aa" },
    { "key": "고급", "w": 27,       "mul": 1.7,  "color": "#46c46e" },
    { "key": "희귀", "w": 9,        "mul": 3.0,  "color": "#3d8bf0" },
    { "key": "영웅", "w": 1.7,      "mul": 5.5,  "color": "#b06ff0" },
    { "key": "전설", "w": 0.12,     "mul": 13.0, "color": "#e6c964" },
    { "key": "신화", "w": 0.00001,  "mul": 25.0, "color": "#ff7a59" }
  ],
  "gacha": {
    "pity": 70,
    "pityResultIndex": 3,
    "pityResetOnRarityGte": 3,
    "luck": { "rareWeightMul": "1 + luck_lv*0.04", "epicWeightMul": "1 + luck_lv*0.03" },
    "cost": { "single": { "energy": 3 }, "ten": { "energy": 27, "gemFallback": 20 } }
  },

  "item": {
    "slotWeights": { "weapon": 40, "top": 20, "head": 16, "legs": 9, "cape": 15 },
    "basePower":   { "weapon": 12, "top": 7,  "head": 6,  "legs": 7, "cape": 5 },
    "powerFormula": "max(1, round(PBASE[slot] * RAR[rarity].mul * rand(0.9,1.2) * (1 + lv*0.07 + region*0.25)))"
  },

  "enhance": {
    "max": 15,
    "powerPerPlus": 0.13,
    "cost": { "gold": "round(40 * 1.5^plus * (rarity+1))", "stone": "round(2 + plus*1.5 + rarity)" }
  },
  "salvage": { "value": "round((rarity+1) * (2+plus) * 1.5 * (1 + wealth_lv*0.08))" },

  "skills": [
    { "id": "atk",     "name": "전투 숙련", "icon": "⚔️", "desc": "전투력 +6%/Lv", "effect": "powerMul *= 1 + atk_lv*0.06" },
    { "id": "luck",    "name": "행운",      "icon": "🍀", "desc": "전리품 등급↑/Lv", "effect": "rareWeight *=(1+0.04/Lv); epicWeight *=(1+0.03/Lv)", "issue": "현재 크리티컬에는 미반영(버그)" },
    { "id": "wealth",  "name": "수색",      "icon": "💰", "desc": "골드·강화석 +8%/Lv", "effect": "wealthMul = (1+wealth_lv*0.08)*(1+rebirth*0.18)" },
    { "id": "haste",   "name": "신속",      "icon": "🌀", "desc": "행동력 회복·공속↑/Lv", "effect": "regenInterval *= (1 - haste_lv*0.05)" },
    { "id": "collect", "name": "수집가",    "icon": "📖", "desc": "도감 보너스 +25%/Lv", "effect": "dexBonus *= (1 + collect_lv*0.25)" }
  ],
  "skillCost": { "pt": 1, "gold": "round(120 * 1.4^currentLv)" },

  "rebirth": {
    "requireLv": "30 + rebirth*10",
    "keep": ["dex", "rebirth", "bestRegion", "bestStage"],
    "grant": { "gems": 30, "skillPt": "rebirth", "gold": "800*rebirth", "stones": "50*rebirth" },
    "permanent": { "powerMul": "1+rebirth*0.25", "goldMul": "1+rebirth*0.18", "idleCapHours": "8+rebirth" }
  },

  "regions": [
    { "name": "폐허가 된 논현 밤거리", "theme": ["#3a1a52", "#160a24"], "enemies": ["z0","z0","z1"] },
    { "name": "감염된 공원",          "theme": ["#173a2a", "#08180f"], "enemies": ["z0","z1","frank"] },
    { "name": "지하 주차장",          "theme": ["#3a2a14", "#180f06"], "enemies": ["z1","jack","skel"] },
    { "name": "무너진 병원",          "theme": ["#3a1622", "#180610"], "enemies": ["z2","goblin","skel","frank"] },
    { "name": "봉쇄된 지하철",        "theme": ["#16273a", "#06121c"], "enemies": ["z2","vampire","alien"] },
    { "name": "변종 연구소",          "theme": ["#241640", "#0e0622"], "enemies": ["z3","troll","boarman"] },
    { "name": "최후의 방어선",        "theme": ["#3a1a52", "#160a24"], "enemies": ["brute","wartotaur","z3","vampire"] }
  ],
  "regionCycle": "index % regions.length",
  "bossByRegion": ["brute2", "troll", "boarman", "wartotaur"],
  "monsters": ["z0","z1","z2","z3","skel","brute","brute2","frank","goblin","troll","vampire","jack","alien","boarman","wartotaur"],

  "pool": {
    "weapon": ["sword","katana","rapier","dagger","scimitar","waraxe","mace","flail","halberd","scythe","spear","saber","longsword","glowsword","trident","longspear"],
    "top": ["shirt","jacket","leather","chainmail","legion","vest","trench","tabard","frock","clothes_shortsleeve_shortsleeve","clothes_shortsleeve_shortsleeve_cardigan","clothes_shortsleeve_shortsleeve_polo","clothes_sleeveless_laced","clothes_sleeveless_sleeveless","clothes_sleeveless_sleeveless1","jacket_iverness","jacket_santa","aprons_apron","aprons_overalls","aprons_suspenders","bandage","clothes_longsleeve_formal","clothes_longsleeve_formal_striped","clothes_longsleeve_longsleeve","clothes_vest_open","waist_belt_belly","waist_belt_double","waist_belt_leather","waist_obi","waist_obi_knot_left","waist_obi_knot_right","waist_sash"],
    "head": ["barbuta","greathelm","horned","kettle","armet","bascinet","morion","nasal","viking","sugarloaf","helmet_armet_simple","helmet_barbarian","helmet_barbarian_nasal","helmet_barbarian_viking","helmet_barbuta_simple","helmet_bascinet_round","helmet_close","helmet_flattop","helmet_legion","helmet_mail","helmet_maximus","helmet_norman","helmet_pointed","helmet_spangenhelm","helmet_sugarloaf_simple","helmet_xeon","accessory_crest","accessory_crest_centurion","accessory_horns_downward_bg","accessory_horns_downward_fg","accessory_horns_short_bg","accessory_plumage","accessory_plumage_centurion","accessory_plumage_legion","accessory_wings_bg","accessory_wings_fg"],
    "legs": ["plate","formal","hose","leggings","armour_plate","cuffed","formal_striped","fur","leggings2","pantaloons","pants2","shorts_short_shorts","shorts_shorts"],
    "cape": ["solid","tat","trim"]
  },
  "dexTotal": 100,

  "attendance": [
    { "gold": 400 }, { "stones": 25 }, { "gems": 10 }, { "gold": 1200 }, { "stones": 50 }, { "gems": 15 }, { "gems": 50 }
  ],
  "chest": {
    "cooldownMs": 7200000,
    "table": [
      { "p": 0.50, "reward": { "stones": "20 + region*5" } },
      { "p": 0.35, "reward": { "gold": "500 + region*120" } },
      { "p": 0.15, "reward": { "gems": 10 } }
    ]
  },
  "dailyMissions": [
    { "id": "pull",  "name": "전리품 10회 뽑기", "goal": 10, "reward": { "gems": 15 } },
    { "id": "kill",  "name": "좀비 60마리 처치",  "goal": 60, "reward": { "stones": 30 } },
    { "id": "enh",   "name": "장비 5회 강화",     "goal": 5,  "reward": { "gold": 500 } },
    { "id": "arena", "name": "아레나 1회 승리",    "goal": 1,  "reward": { "gems": 20 } }
  ],
  "arena": {
    "cooldownMs": 10800000,
    "rollRange": [0.85, 1.25],
    "win": { "arenaPts": [12, 22], "gems": 4 },
    "lose": { "arenaPts": -8, "min": 0 }
  },

  "ranking": {
    "boards": ["pow", "rebirth", "lv", "bestStage", "dex", "arena"],
    "nickFormat": "닉/지역/성별/년",
    "excludeOpsFromCompetition": true
  },

  "knownIssues": [
    "critChance = 0.05 + luck*0.0 → 행운이 크리에 미반영(버그)",
    "가챠/강화/구매 차감이 클라에만 존재 → 서버 RPC 검증 필요",
    "신화 ~1/1000만 → 사실상 획득 불가(의도 확인 필요)",
    "전투력에 진행도(bestStage*2) 비중 재튜닝 필요",
    "봇 랭킹과 실서버 랭킹 혼재 → 실데이터 단일 경로로 단순화",
    "익명+localStorage 신원 → 카카오 로그인+클라우드 세이브로 전환(결정됨)"
  ]
}
